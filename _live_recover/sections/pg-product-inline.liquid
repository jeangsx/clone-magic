      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_pad_x",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
