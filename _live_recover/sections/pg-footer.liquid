{% comment %} Estilos editables (toda la seccion) {% endcomment %}
<div
  class="pg-sec-style"
  style="
    --pg-sec-pad-y: {{ section.settings.style_pad_y }}px;
    --pg-sec-pad-x: {{ section.settings.style_pad_x }}px;
    --pg-sec-max: {% if section.settings.style_max_width > 0 %}{{ section.settings.style_max_width }}px{% else %}none{% endif %};
    --pg-sec-h-size: {{ section.settings.style_heading_size }}px;
    --pg-sec-t-size: {{ section.settings.style_text_size }}px;
    --pg-sec-bg: {{ section.settings.style_bg | default: 'transparent' }};
    --pg-sec-h-color: {{ section.settings.style_heading_color }};
    --pg-sec-t-color: {{ section.settings.style_text_color }};
    --pg-sec-btn-fs: {{ section.settings.style_btn_font }}px;
    --pg-sec-btn-py: {{ section.settings.style_btn_pad_y }}px;
    --pg-sec-btn-px: {{ section.settings.style_btn_pad_x }}px;
    --pg-sec-btn-radius: {{ section.settings.style_btn_radius }}px;
    --pg-sec-btn-bg: {{ section.settings.style_btn_bg }};
    --pg-sec-btn-color: {{ section.settings.style_btn_text }};
  "
>
<div id="footer" class="body_full_nomar footer">
  <div id="footer_top" class="top">
    <div class="body_full wrapper">
      {% if section.settings.disclaimer != blank %}
        <div>{{ section.settings.disclaimer }}</div>
      {% endif %}
      {% if section.settings.legal_links != blank %}
        <div class="footer-terms">{{ section.settings.legal_links }}</div>
      {% endif %}
      <ul id="soc-foot" style="list-style:none;padding:0;">
        {% for block in section.blocks %}
          {% if block.settings.url != blank %}
            <li style="display:inline;" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.url }}" target="_blank" rel="noopener">
                {% if block.settings.icon != blank %}
                  <img src="{{ block.settings.icon | image_url: width: 64 }}" alt="{{ block.settings.label | escape }}" style="margin-right:5px;" width="32" height="32" loading="lazy">
                {% elsif block.settings.icon_url != blank %}
                  <img src="{{ block.settings.icon_url }}" alt="{{ block.settings.label | escape }}" style="margin-right:5px;" width="32" height="32" loading="lazy">
                {% else %}
                  {{ block.settings.label }}
                {% endif %}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
      <p>©Copyright <span class="currentYear"></span>{{ section.settings.copyright_suffix }}</p>
      {% if section.settings.note != blank %}
        <p>{{ section.settings.note }}</p>
      {% endif %}
    </div>
  </div>
  <div id="footer_bottom" class="bottom">
    <div class="body_center" style="text-align:center;">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo != blank %}
          <img id="footer_logo" src="{{ section.settings.logo | image_url: width: 280 }}" alt="{{ shop.name }}" width="200" height="80" loading="lazy">
        {% else %}
          <img id="footer_logo" src="{{ section.settings.logo_url }}" alt="ProstaGenix" title="ProstaGenix" width="200" height="80" loading="lazy">
        {% endif %}
      </a>
    </div>
  </div>
</div>
</div>

{% schema %}
{
  "name": "PG Footer",
  "tag": "section",
  "class": "pg-section-footer",
  "settings": [
    {
      "type": "richtext",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "<p>These statements have not been evaluated by the Food and Drug Administration and are for informational purposes only.</p>"
    },
    {
      "type": "richtext",
      "id": "legal_links",
      "label": "Links legales",
      "default": "<p><a href=\"https://www.prostagenix.com/terms.html\">terms &amp; conditions</a> | <a href=\"https://www.prostagenix.com/privacy.html\">privacy policy</a> | <a href=\"https://www.prostagenix.com/guarantee.html\">guarantee/return policy</a></p>"
    },
    {
      "type": "text",
      "id": "copyright_suffix",
      "label": "Texto después del año",
      "default": " ProstaGenix, LLC. All rights reserved."
    },
    {
      "type": "text",
      "id": "note",
      "label": "Nota",
      "default": "*Larry King is a paid endorser of ProstaGenix."
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo footer"
    },
    {
      "type": "text",
      "id": "logo_url",
      "label": "URL logo (fallback)",
      "default": "https://www.prostagenix.com/190109/img/logo.png"
    },
    {
      "type": "header",
      "content": "Estilos de seccion"
    },
    {
      "type": "range",
      "id": "style_pad_y",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_pad_x",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_max_width",
      "min": 0,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Ancho maximo (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_heading_size",
      "min": 14,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Tamano titulos",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano texto",
      "default": 16
    },
    {
      "type": "color",
      "id": "style_bg",
      "label": "Fondo seccion"
    },
    {
      "type": "color",
      "id": "style_heading_color",
      "label": "Color titulos",
      "default": "#0b1a3a"
    },
    {
      "type": "color",
      "id": "style_text_color",
      "label": "Color texto",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "style_btn_font",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano botones",
      "default": 15
    },
    {
      "type": "range",
      "id": "style_btn_pad_y",
      "min": 6,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Padding vertical boton",
      "default": 14
    },
    {
      "type": "range",
      "id": "style_btn_pad_x",
      "min": 10,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal boton",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_btn_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio botones",
      "default": 24
    },
    {
      "type": "color",
      "id": "style_btn_bg",
      "label": "Boton fondo",
      "default": "#e65600"
    },
    {
      "type": "color",
      "id": "style_btn_text",
      "label": "Boton texto",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "social",
      "name": "Red social",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Nombre",
          "default": "Facebook"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icono"
        },
        {
          "type": "text",
          "id": "icon_url",
          "label": "URL icono",
          "default": "https://www.prostagenix.com/images/footer_social_facebook.png"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PG Footer",
      "blocks": [
        {
          "type": "social",
          "settings": {
            "label": "Facebook",
            "url": "https://www.facebook.com/prostagenix/",
            "icon_url": "https://www.prostagenix.com/images/footer_social_facebook.png"
          }
        },
        {
          "type": "social",
          "settings": {
            "label": "Twitter",
            "url": "https://twitter.com/prostagenix",
            "icon_url": "https://www.prostagenix.com/images/footer_social_twitter.png"
          }
        },
        {
          "type": "social",
          "settings": {
            "label": "Instagram",
            "url": "https://www.instagram.com/prostagenixpills",
            "icon_url": "https://www.prostagenix.com/images/footer_social_instagram.png"
          }
        }
      ]
    }
  ]
}
{% endschema %}
