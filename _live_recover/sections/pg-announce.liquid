{% comment %} Estilos editables (toda la seccion) {% endcomment %}
<div
  class="pg-sec-style"
  style="
    --pg-sec-pad-y: {{ section.settings.style_pad_y }}px;
    --pg-sec-pad-x: {{ section.settings.style_pad_x }}px;
    --pg-sec-max: {% if section.settings.style_max_width > 0 %}{{ section.settings.style_max_width }}px{% else %}none{% endif %};
    --pg-sec-h-size: {{ section.settings.style_heading_size }}px;
    --pg-sec-t-size: {{ section.settings.style_text_size }}px;
    --pg-sec-bg: {{ section.settings.style_bg | default: 'transparent' }};
    --pg-sec-h-color: {{ section.settings.style_heading_color }};
    --pg-sec-t-color: {{ section.settings.style_text_color }};
    --pg-sec-btn-fs: {{ section.settings.style_btn_font }}px;
    --pg-sec-btn-py: {{ section.settings.style_btn_pad_y }}px;
    --pg-sec-btn-px: {{ section.settings.style_btn_pad_x }}px;
    --pg-sec-btn-radius: {{ section.settings.style_btn_radius }}px;
    --pg-sec-btn-bg: {{ section.settings.style_btn_bg }};
    --pg-sec-btn-color: {{ section.settings.style_btn_text }};
  "
>
{% comment %} Barra de anuncios rotativa — editable por bloques {% endcomment %}
<div class="lv-announce">
  <div class="lv-announce-track" aria-hidden="false">
    {% for block in section.blocks %}
      <span class="lv-announce-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      {% unless forloop.last %}<span class="lv-announce-sep">•</span>{% endunless %}
    {% endfor %}
    {% comment %} Duplicar para loop visual {% endcomment %}
    {% for block in section.blocks %}
      <span class="lv-announce-sep">•</span>
      <span class="lv-announce-item">{{ block.settings.text }}</span>
    {% endfor %}
  </div>
</div>
</div>

{% schema %}
{
  "name": "PG Anuncios",
  "tag": "section",
  "class": "pg-section-announce",
  "settings": [
    {
      "type": "header",
      "content": "Estilos de seccion"
    },
    {
      "type": "range",
      "id": "style_pad_y",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_pad_x",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_max_width",
      "min": 0,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Ancho maximo (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_heading_size",
      "min": 14,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Tamano titulos",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano texto",
      "default": 16
    },
    {
      "type": "color",
      "id": "style_bg",
      "label": "Fondo seccion"
    },
    {
      "type": "color",
      "id": "style_heading_color",
      "label": "Color titulos",
      "default": "#0b1a3a"
    },
    {
      "type": "color",
      "id": "style_text_color",
      "label": "Color texto",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "style_btn_font",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano botones",
      "default": 15
    },
    {
      "type": "range",
      "id": "style_btn_pad_y",
      "min": 6,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Padding vertical boton",
      "default": 14
    },
    {
      "type": "range",
      "id": "style_btn_pad_x",
      "min": 10,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal boton",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_btn_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio botones",
      "default": 24
    },
    {
      "type": "color",
      "id": "style_btn_bg",
      "label": "Boton fondo",
      "default": "#e65600"
    },
    {
      "type": "color",
      "id": "style_btn_text",
      "label": "Boton texto",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Mensaje",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "✨ ¡Bienvenido(a) a ProstaGenix! ✨"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PG Anuncios",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "text": "✨ ¡Bienvenido(a) a ProstaGenix! ✨"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "💎 Garantía de 90 Días · Devolución Total"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "🔥 ¡Envíos a TODO el Perú! 🇵🇪"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "⚡ Hasta 70% OFF · ¡Solo hoy!"
          }
        }
      ]
    }
  ]
}
{% endschema %}
