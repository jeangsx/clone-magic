{% comment %} Estilos editables (toda la seccion) {% endcomment %}
<div
  class="pg-sec-style"
  style="
    --pg-sec-pad-y: {{ section.settings.style_pad_y }}px;
    --pg-sec-pad-x: {{ section.settings.style_pad_x }}px;
    --pg-sec-max: {% if section.settings.style_max_width > 0 %}{{ section.settings.style_max_width }}px{% else %}none{% endif %};
    --pg-sec-h-size: {{ section.settings.style_heading_size }}px;
    --pg-sec-t-size: {{ section.settings.style_text_size }}px;
    --pg-sec-bg: {{ section.settings.style_bg | default: 'transparent' }};
    --pg-sec-h-color: {{ section.settings.style_heading_color }};
    --pg-sec-t-color: {{ section.settings.style_text_color }};
    --pg-sec-btn-fs: {{ section.settings.style_btn_font }}px;
    --pg-sec-btn-py: {{ section.settings.style_btn_pad_y }}px;
    --pg-sec-btn-px: {{ section.settings.style_btn_pad_x }}px;
    --pg-sec-btn-radius: {{ section.settings.style_btn_radius }}px;
    --pg-sec-btn-bg: {{ section.settings.style_btn_bg }};
    --pg-sec-btn-color: {{ section.settings.style_btn_text }};
  "
>
<div class="larry_dudley body_full_nomar">
  <div class="body_full wrapper">
    {% for block in section.blocks %}
      <div class="split" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="{{ block.settings.name | escape }}"
            width="400"
            height="400"
            loading="lazy"
          >
        {% elsif block.settings.image_url != blank %}
          <img src="{{ block.settings.image_url }}" alt="{{ block.settings.name | escape }}" width="400" height="400" loading="lazy">
        {% endif %}
        <div class="copy">
          {% if block.settings.quote != blank %}
            <span>&ldquo;{{ block.settings.quote }}&rdquo;</span>
          {% endif %}
          {% if block.settings.name != blank %}
            <p><strong>- {{ block.settings.name }}</strong></p>
          {% endif %}
          {% if block.settings.line_1 != blank %}<p>{{ block.settings.line_1 }}</p>{% endif %}
          {% if block.settings.line_2 != blank %}<p>{{ block.settings.line_2 }}</p>{% endif %}
          {% if block.settings.line_3 != blank %}<p>{{ block.settings.line_3 }}</p>{% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>
</div>

{% schema %}
{
  "name": "PG Testimonios",
  "tag": "section",
  "class": "pg-section-testimonials",
  "settings": [
    {
      "type": "header",
      "content": "Estilos de seccion"
    },
    {
      "type": "range",
      "id": "style_pad_y",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_pad_x",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_max_width",
      "min": 0,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Ancho maximo (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_heading_size",
      "min": 14,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Tamano titulos",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano texto",
      "default": 16
    },
    {
      "type": "color",
      "id": "style_bg",
      "label": "Fondo seccion"
    },
    {
      "type": "color",
      "id": "style_heading_color",
      "label": "Color titulos",
      "default": "#0b1a3a"
    },
    {
      "type": "color",
      "id": "style_text_color",
      "label": "Color texto",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "style_btn_font",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano botones",
      "default": 15
    },
    {
      "type": "range",
      "id": "style_btn_pad_y",
      "min": 6,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Padding vertical boton",
      "default": 14
    },
    {
      "type": "range",
      "id": "style_btn_pad_x",
      "min": 10,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal boton",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_btn_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio botones",
      "default": 24
    },
    {
      "type": "color",
      "id": "style_btn_bg",
      "label": "Boton fondo",
      "default": "#e65600"
    },
    {
      "type": "color",
      "id": "style_btn_text",
      "label": "Boton texto",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "URL imagen (si no subes foto)",
          "default": "https://www.prostagenix.com/images/home/dudley-danoff.png"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Cita",
          "default": "I highly recommend ProstaGenix to all men with prostate concerns."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre",
          "default": "Dudley Danoff, M.D., F.A.C.S."
        },
        {
          "type": "text",
          "id": "line_1",
          "label": "Línea 1",
          "default": "Cedars-Sinai Medical Center"
        },
        {
          "type": "text",
          "id": "line_2",
          "label": "Línea 2",
          "default": "Tower Urology"
        },
        {
          "type": "text",
          "id": "line_3",
          "label": "Línea 3",
          "default": "Yale School of Medicine"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PG Testimonios",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "image_url": "https://www.prostagenix.com/images/home/dudley-danoff.png",
            "quote": "I highly recommend ProstaGenix to all men with prostate concerns. It is a natural alpha-blocker which is what you want. It is very effective, a truly remarkable product.",
            "name": "Dudley Danoff, M.D., F.A.C.S.",
            "line_1": "Cedars-Sinai Medical Center",
            "line_2": "Tower Urology",
            "line_3": "Yale School of Medicine"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "image_url": "https://www.prostagenix.com/special/special-offer/img/neil-diamond.png",
            "quote": "I have battled nagging prostate issues for years and I tried many of the products on the market and nothing worked. But then I discovered ProstaGenix and it was a game changer!",
            "name": "Neil Diamond",
            "line_1": "Legendary American",
            "line_2": "Singer-Songwriter",
            "line_3": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
