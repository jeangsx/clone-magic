{% liquid
  assign offers_collection = section.settings.collection
  if offers_collection == blank and collection != blank
    assign offers_collection = collection
  endif
  assign heading = section.settings.heading
  if heading == blank and collection != blank
    assign heading = collection.title
  endif
%}

{% if section.settings.subheading != blank %}
  <div class="pg-simple" style="text-align:center;padding-bottom:0;margin-bottom:0;">
    <p style="color:#555;font-weight:600;">{{ section.settings.subheading }}</p>
  </div>
{% endif %}

{% render 'pg-offers-list',
  collection: offers_collection,
  heading: heading,
  guarantee: section.settings.guarantee_text
%}

{% schema %}
{
  "name": "ProstaGenix Offers",
  "tag": "section",
  "class": "pg-offers-page",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Special Internet-Only Offer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Elige tu paquete y ahorra hoy"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "Garantía 90 Días · Devolución Total"
    }
  ],
  "presets": [
    {
      "name": "ProstaGenix Offers"
    }
  ]
}
{% endschema %}
