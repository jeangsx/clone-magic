{% comment %} Estilos editables (toda la seccion) {% endcomment %}
<div
  class="pg-sec-style pg-sec-align-{{ section.settings.style_align }}{% if section.settings.style_hide_mobile %} pg-sec-hide-mobile{% endif %}{% if section.settings.style_hide_desktop %} pg-sec-hide-desktop{% endif %}"
  style="
    --pg-sec-pad-y: {{ section.settings.style_pad_y }}px;
    --pg-sec-pad-x: {{ section.settings.style_pad_x }}px;
    --pg-sec-max: {% if section.settings.style_max_width > 0 %}{{ section.settings.style_max_width }}px{% else %}none{% endif %};
    --pg-sec-h-size: {{ section.settings.style_heading_size }}px;
    --pg-sec-t-size: {{ section.settings.style_text_size }}px;
    --pg-sec-bg: {{ section.settings.style_bg | default: 'transparent' }};
    --pg-sec-h-color: {{ section.settings.style_heading_color }};
    --pg-sec-t-color: {{ section.settings.style_text_color }};
    --pg-sec-btn-fs: {{ section.settings.style_btn_font }}px;
    --pg-sec-btn-py: {{ section.settings.style_btn_pad_y }}px;
    --pg-sec-btn-px: {{ section.settings.style_btn_pad_x }}px;
    --pg-sec-btn-radius: {{ section.settings.style_btn_radius }}px;
    --pg-sec-btn-bg: {{ section.settings.style_btn_bg }};
    --pg-sec-btn-color: {{ section.settings.style_btn_text }};
    --pg-sec-min-h: {{ section.settings.style_min_height }}px;
    --pg-sec-img-w: {{ section.settings.style_image_width }}%;
    --pg-sec-img-h: {% if section.settings.style_image_max_height > 0 %}{{ section.settings.style_image_max_height }}px{% else %}none{% endif %};
    --pg-sec-img-radius: {{ section.settings.style_image_radius }}px;
  "
>
<section class="pg-simple pg-cart">
  <h1 style="color:var(--pg-blue,#054497);font-weight:900;">Carrito</h1>

  {% if cart.item_count == 0 %}
    <p>Tu carrito está vacío.</p>
    <p><a href="{{ routes.all_products_collection_url }}">Ver productos</a></p>
  {% else %}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <table style="width:100%;border-collapse:collapse;margin:24px 0;">
        <thead>
          <tr style="text-align:left;border-bottom:2px solid var(--pg-blue,#054497);">
            <th style="padding:8px;">Producto</th>
            <th style="padding:8px;">Precio</th>
            <th style="padding:8px;">Cant.</th>
            <th style="padding:8px;">Total</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr style="border-bottom:1px solid #e3e6ee;">
              <td style="padding:12px 8px;">
                <a href="{{ item.url }}" style="color:var(--pg-blue,#054497);font-weight:700;">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}
                  <div style="font-size:13px;color:#666;">{{ item.variant.title }}</div>
                {% endunless %}
                <div style="margin-top:6px;">
                  <a href="{{ item.url_to_remove }}" style="font-size:12px;color:#888;">Quitar</a>
                </div>
              </td>
              <td style="padding:12px 8px;">{{ item.final_price | money }}</td>
              <td style="padding:12px 8px;">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:64px;padding:6px;">
              </td>
              <td style="padding:12px 8px;font-weight:800;">{{ item.final_line_price | money }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:space-between;">
        <button type="submit" name="update" style="padding:10px 18px;border:2px solid var(--pg-blue,#054497);background:#fff;color:var(--pg-blue,#054497);font-weight:800;border-radius:10px;cursor:pointer;">
          Actualizar
        </button>
        <div style="text-align:right;">
          <div style="font-size:20px;font-weight:900;margin-bottom:10px;">
            Total: {{ cart.total_price | money }}
          </div>
          <button type="submit" name="checkout" style="padding:14px 28px;border:0;background:var(--pg-orange,#f39200);color:#fff;font-weight:900;border-radius:999px;cursor:pointer;letter-spacing:1px;">
            IR A PAGAR
          </button>
        </div>
      </div>
    </form>
  {% endif %}
</section>
</div>

{% schema %}
{
  "name": "ProstaGenix Cart",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Estilos de seccion"
    },
    {
      "type": "range",
      "id": "style_pad_y",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_pad_x",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_max_width",
      "min": 0,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Ancho maximo (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_heading_size",
      "min": 14,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Tamano titulos",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano texto",
      "default": 16
    },
    {
      "type": "color",
      "id": "style_bg",
      "label": "Fondo seccion"
    },
    {
      "type": "color",
      "id": "style_heading_color",
      "label": "Color titulos",
      "default": "#0b1a3a"
    },
    {
      "type": "color",
      "id": "style_text_color",
      "label": "Color texto",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "style_btn_font",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano botones",
      "default": 15
    },
    {
      "type": "range",
      "id": "style_btn_pad_y",
      "min": 6,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Padding vertical boton",
      "default": 14
    },
    {
      "type": "range",
      "id": "style_btn_pad_x",
      "min": 10,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal boton",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_btn_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio botones",
      "default": 24
    },
    {
      "type": "color",
      "id": "style_btn_bg",
      "label": "Boton fondo",
      "default": "#e65600"
    },
    {
      "type": "color",
      "id": "style_btn_text",
      "label": "Boton texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "style_min_height",
      "min": 0,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Altura minima (0 = auto)",
      "default": 0
    },
    {
      "type": "select",
      "id": "style_align",
      "label": "Alineacion del contenido",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "style_image_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Ancho maximo de imagenes",
      "default": 100
    },
    {
      "type": "range",
      "id": "style_image_max_height",
      "min": 0,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Alto maximo imagenes (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_image_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio de imagenes",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "style_hide_mobile",
      "label": "Ocultar en celular",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "style_hide_desktop",
      "label": "Ocultar en desktop",
      "default": false
    }
  ]
}
{% endschema %}
