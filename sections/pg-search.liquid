<section class="pg-simple">
  <h1 style="color:var(--pg-blue,#054497);font-weight:900;">Buscar</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" style="margin:20px 0 32px;display:flex;gap:8px;flex-wrap:wrap;">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Buscar productos…"
      style="flex:1;min-width:200px;padding:12px 14px;border:2px solid #e3e6ee;border-radius:10px;"
    >
    <button type="submit" style="padding:12px 20px;background:var(--pg-blue,#054497);color:#fff;border:0;border-radius:10px;font-weight:800;cursor:pointer;">
      Buscar
    </button>
  </form>

  {% if search.performed %}
    {% if search.results_count == 0 %}
      <p>No hay resultados para “{{ search.terms | escape }}”.</p>
    {% else %}
      <p style="margin-bottom:16px;color:#555;">{{ search.results_count }} resultado(s)</p>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:16px;">
        {% for item in search.results %}
          <li style="padding:16px;border:1px solid #e3e6ee;border-radius:12px;">
            <a href="{{ item.url }}" style="font-weight:800;color:var(--pg-blue,#054497);text-decoration:none;">{{ item.title }}</a>
            {% if item.object_type == 'product' %}
              <div style="margin-top:6px;font-weight:700;">{{ item.price | money }}</div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  {% endif %}
</section>

{% schema %}
{
  "name": "ProstaGenix Search",
  "tag": "section",
  "settings": []
}
{% endschema %}
