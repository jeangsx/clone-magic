<section class="pg-simple" style="text-align:center;max-width:420px;">
  <img
    src="https://www.prostagenix.com/190109/img/logo.png"
    alt="{{ shop.name }}"
    width="200"
    height="60"
    style="max-width:200px;height:auto;margin:0 auto 24px;display:block;"
  >
  <h1 style="color:var(--pg-blue,#054497);font-weight:900;margin-bottom:8px;">Próximamente</h1>
  <p style="color:#555;margin-bottom:24px;">Ingresa la contraseña para ver la tienda.</p>

  {% form 'storefront_password' %}
    {{ form.errors | default_errors }}
    <div style="display:flex;flex-direction:column;gap:12px;">
      <input
        type="password"
        name="password"
        placeholder="Contraseña"
        style="padding:12px 14px;border:2px solid #e3e6ee;border-radius:10px;text-align:center;"
      >
      <button type="submit" style="padding:14px;background:var(--pg-orange,#f39200);color:#fff;border:0;border-radius:999px;font-weight:900;cursor:pointer;">
        Entrar
      </button>
    </div>
  {% endform %}
</section>

{% schema %}
{
  "name": "ProstaGenix Password",
  "tag": "section",
  "settings": []
}
{% endschema %}
