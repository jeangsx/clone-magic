{% comment %} Estilos editables (toda la seccion) {% endcomment %}
<div
  class="pg-sec-style pg-sec-align-{{ section.settings.style_align }}{% if section.settings.style_hide_mobile %} pg-sec-hide-mobile{% endif %}{% if section.settings.style_hide_desktop %} pg-sec-hide-desktop{% endif %}"
  style="
    --pg-sec-pad-y: {{ section.settings.style_pad_y }}px;
    --pg-sec-pad-x: {{ section.settings.style_pad_x }}px;
    --pg-sec-max: {% if section.settings.style_max_width > 0 %}{{ section.settings.style_max_width }}px{% else %}none{% endif %};
    --pg-sec-h-size: {{ section.settings.style_heading_size }}px;
    --pg-sec-t-size: {{ section.settings.style_text_size }}px;
    --pg-sec-bg: {{ section.settings.style_bg | default: 'transparent' }};
    --pg-sec-h-color: {{ section.settings.style_heading_color }};
    --pg-sec-t-color: {{ section.settings.style_text_color }};
    --pg-sec-btn-fs: {{ section.settings.style_btn_font }}px;
    --pg-sec-btn-py: {{ section.settings.style_btn_pad_y }}px;
    --pg-sec-btn-px: {{ section.settings.style_btn_pad_x }}px;
    --pg-sec-btn-radius: {{ section.settings.style_btn_radius }}px;
    --pg-sec-btn-bg: {{ section.settings.style_btn_bg }};
    --pg-sec-btn-color: {{ section.settings.style_btn_text }};
    --pg-sec-min-h: {{ section.settings.style_min_height }}px;
    --pg-sec-img-w: {{ section.settings.style_image_width }}%;
    --pg-sec-img-h: {% if section.settings.style_image_max_height > 0 %}{{ section.settings.style_image_max_height }}px{% else %}none{% endif %};
    --pg-sec-img-radius: {{ section.settings.style_image_radius }}px;
  "
>
<div class="faqs body_full">
  <div class="body_full wrapper borders">
    {% if section.settings.title != blank %}
      <span class="heading title">{{ section.settings.title }}</span>
    {% endif %}
    {% for block in section.blocks %}
      <div {{ block.shopify_attributes }}>
        {% if block.settings.question != blank %}
          <span class="heading q">{{ block.settings.question }}</span>
        {% endif %}
        {% if block.type == 'answer' %}
          {% if block.settings.answer != blank %}
            <div class="a">{{ block.settings.answer }}</div>
          {% endif %}
        {% elsif block.type == 'ingredients' %}
          <div class="ing">
            {% if block.settings.facts_image != blank %}
              <img src="{{ block.settings.facts_image | image_url: width: 600 }}" alt="Supplement facts" width="400" height="400" loading="lazy">
            {% elsif block.settings.facts_url != blank %}
              <img src="{{ block.settings.facts_url }}" alt="supplement facts" width="400" height="400" loading="lazy">
            {% endif %}
            {% if block.settings.bottle_image != blank %}
              <img src="{{ block.settings.bottle_image | image_url: width: 600 }}" alt="Bottle back" width="400" height="400" loading="lazy">
            {% elsif block.settings.bottle_url != blank %}
              <img src="{{ block.settings.bottle_url }}" alt="ProstaGenix - back of bottle" width="400" height="400" loading="lazy">
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>
</div>

{% schema %}
{
  "name": "PG FAQs",
  "tag": "section",
  "class": "pg-section-faqs",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "FAQs"
    },
    {
      "type": "header",
      "content": "Estilos de seccion"
    },
    {
      "type": "range",
      "id": "style_pad_y",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_pad_x",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_max_width",
      "min": 0,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Ancho maximo (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_heading_size",
      "min": 14,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Tamano titulos",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano texto",
      "default": 16
    },
    {
      "type": "color",
      "id": "style_bg",
      "label": "Fondo seccion"
    },
    {
      "type": "color",
      "id": "style_heading_color",
      "label": "Color titulos",
      "default": "#0b1a3a"
    },
    {
      "type": "color",
      "id": "style_text_color",
      "label": "Color texto",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "style_btn_font",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano botones",
      "default": 15
    },
    {
      "type": "range",
      "id": "style_btn_pad_y",
      "min": 6,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Padding vertical boton",
      "default": 14
    },
    {
      "type": "range",
      "id": "style_btn_pad_x",
      "min": 10,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal boton",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_btn_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio botones",
      "default": 24
    },
    {
      "type": "color",
      "id": "style_btn_bg",
      "label": "Boton fondo",
      "default": "#e65600"
    },
    {
      "type": "color",
      "id": "style_btn_text",
      "label": "Boton texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "style_min_height",
      "min": 0,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Altura minima (0 = auto)",
      "default": 0
    },
    {
      "type": "select",
      "id": "style_align",
      "label": "Alineacion del contenido",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "style_image_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Ancho maximo de imagenes",
      "default": 100
    },
    {
      "type": "range",
      "id": "style_image_max_height",
      "min": 0,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Alto maximo imagenes (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_image_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio de imagenes",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "style_hide_mobile",
      "label": "Ocultar en celular",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "style_hide_desktop",
      "label": "Ocultar en desktop",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "answer",
      "name": "Pregunta + respuesta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "How many bottles should I order?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>The most popular order for new customers is the 3 bottle package.</p>"
        }
      ]
    },
    {
      "type": "ingredients",
      "name": "Ingredientes (imágenes)",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "What are the ingredients in ProstaGenix?"
        },
        {
          "type": "image_picker",
          "id": "facts_image",
          "label": "Supplement facts"
        },
        {
          "type": "text",
          "id": "facts_url",
          "label": "URL facts (fallback)",
          "default": "https://www.prostagenix.com/special/special-offer/img/supplement-facts.jpg"
        },
        {
          "type": "image_picker",
          "id": "bottle_image",
          "label": "Botella reverso"
        },
        {
          "type": "text",
          "id": "bottle_url",
          "label": "URL botella (fallback)",
          "default": "https://www.prostagenix.com/special/special-offer/img/prostagenix-bottle-back.png"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PG FAQs",
      "blocks": [
        {
          "type": "answer",
          "settings": {
            "question": "How many bottles should I order?",
            "answer": "<p>The most popular order for new customers is the 3 bottle package, and that's what I recommend to start with.</p>"
          }
        },
        {
          "type": "answer",
          "settings": {
            "question": "How long does a bottle last and how do I use ProstaGenix?",
            "answer": "<p>Each bottle is a full 30-day supply. Simply take three capsules every day.</p>"
          }
        },
        {
          "type": "ingredients"
        },
        {
          "type": "answer",
          "settings": {
            "question": "How safe is ProstaGenix?",
            "answer": "<p>ProstaGenix is completely safe. It contains only 100% safe and natural ingredients.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
