{% assign heading = section.settings.heading %}
{% assign guarantee = section.settings.guarantee_text %}
{% assign cta_label = section.settings.cta_label %}
{% assign selected = section.settings.collection %}
{% assign limit = section.settings.products_limit %}

<section
  class="ns-offers"
  style="--ns-accent: {{ section.settings.accent_color }}; --ns-bg: {{ section.settings.background_color }}; --ns-card: {{ section.settings.card_color }}; --ns-radius: {{ section.settings.card_radius }}px;"
>
  <div class="ns-offers__inner">
    {% if heading != blank %}
      <div class="ns-offers__header">
        <h2 class="ns-offers__heading">{{ heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="ns-offers__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if selected == blank %}
      <p class="ns-offers__empty">Selecciona una colección en el editor del tema.</p>
    {% elsif selected.products_count == 0 %}
      <p class="ns-offers__empty">No hay productos en esta colección.</p>
    {% else %}
      {% if section.settings.show_collection_title %}
        <h3 class="ns-offers__collection-title">{{ selected.title }}</h3>
        {% if selected.description != blank %}
          <div class="ns-offers__collection-desc">{{ selected.description }}</div>
        {% endif %}
      {% endif %}

      <div class="ns-offers__list">
        {% for product in selected.products limit: limit %}
          {% assign pitch = product.metafields.custom.short_pitch.value %}
          {% assign badge = product.metafields.custom.badge_text.value %}
          {% if badge == blank %}
            {% assign badge = 'OFERTA' %}
          {% endif %}

          {% assign price = product.price %}
          {% assign compare = product.compare_at_price %}
          {% if compare == blank %}
            {% assign compare = price | times: 25 | divided_by: 10 %}
          {% endif %}
          {% if compare <= price %}
            {% assign compare = price | times: 25 | divided_by: 10 %}
          {% endif %}

          {% assign save_amount = compare | minus: price %}
          {% assign save_pct = 0 %}
          {% if compare > 0 %}
            {% assign save_pct = save_amount | times: 100 | divided_by: compare %}
          {% endif %}

          <article class="ns-offer-card">
            <div class="ns-offer-card__media">
              <span class="ns-offer-card__badge">{{ badge }}</span>
              {% if product.featured_image %}
                <img
                  class="ns-offer-card__image"
                  src="{{ product.featured_image | image_url: width: 900 }}"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                  width="900"
                  height="900"
                >
              {% endif %}
            </div>

            <div class="ns-offer-card__copy">
              <h3 class="ns-offer-card__title">{{ product.title }}</h3>
              {% if pitch != blank %}
                <p class="ns-offer-card__pitch">{{ pitch }}</p>
              {% endif %}

              <ul class="ns-offer-card__meta">
                <li>
                  Precio retail
                  <s>{{ compare | money }}</s>
                </li>
                <li>
                  Ahorras
                  <strong>{{ save_amount | money }}</strong>
                </li>
              </ul>

              <div class="ns-offer-card__price-block">
                <span class="ns-offer-card__label">INSTANT SAVINGS</span>
                <div class="ns-offer-card__price">{{ price | money }}</div>
                <span class="ns-offer-card__pct">{{ save_pct }}% OFF</span>
              </div>

              <div class="ns-offer-card__actions">
                <a class="ns-offer-card__cta" href="{{ product.url }}">
                  {% if cta_label != blank %}
                    {{ cta_label }}
                  {% else %}
                    ORDER NOW
                  {% endif %}
                </a>
                {% if guarantee != blank %}
                  <p class="ns-offer-card__guarantee">{{ guarantee }}</p>
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .ns-offers {
    background: var(--ns-bg, #f3f3f3);
    padding: 48px 16px 64px;
    color: #121212;
    font-family: inherit;
  }
  .ns-offers__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .ns-offers__header {
    text-align: center;
    margin-bottom: 32px;
  }
  .ns-offers__heading {
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #121212;
  }
  .ns-offers__subheading {
    margin: 12px auto 0;
    max-width: 36rem;
    font-size: 1.05rem;
    line-height: 1.5;
    color: #555;
  }
  .ns-offers__collection-title {
    margin: 0 0 8px;
    font-size: 1.35rem;
    font-weight: 800;
  }
  .ns-offers__collection-desc {
    margin: 0 0 20px;
    color: #555;
    font-size: 0.95rem;
  }
  .ns-offers__list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .ns-offers__empty {
    text-align: center;
    color: #555;
    background: var(--ns-card, #fff);
    border-radius: var(--ns-radius, 24px);
    padding: 28px;
  }
  .ns-offer-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: 20px;
    align-items: center;
    padding: 18px;
    background: var(--ns-card, #fff);
    border-radius: var(--ns-radius, 24px);
    border: 1px solid rgba(18, 18, 18, 0.06);
    box-shadow: 0 10px 30px rgba(18, 18, 18, 0.04);
  }
  .ns-offer-card__media {
    position: relative;
    background: #f7f5f9;
    border-radius: calc(var(--ns-radius, 24px) - 6px);
    padding: 18px;
    text-align: center;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ns-offer-card__badge {
    position: absolute;
    top: 14px;
    right: 14px;
    background: var(--ns-accent, #6d388b);
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 12px;
    border-radius: 999px;
  }
  .ns-offer-card__image {
    max-width: 100%;
    max-height: 280px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .ns-offer-card__copy {
    padding: 8px 10px 8px 4px;
  }
  .ns-offer-card__title {
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .ns-offer-card__pitch {
    margin: 8px 0 0;
    font-size: 0.95rem;
    color: #555;
    line-height: 1.45;
  }
  .ns-offer-card__meta {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: #444;
  }
  .ns-offer-card__meta li {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .ns-offer-card__meta s {
    color: #9a9a9a;
  }
  .ns-offer-card__meta strong {
    color: #2f7a3a;
  }
  .ns-offer-card__price-block {
    margin-top: 14px;
  }
  .ns-offer-card__label {
    display: block;
    color: var(--ns-accent, #6d388b);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }
  .ns-offer-card__price {
    margin-top: 2px;
    font-size: clamp(2rem, 4vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #121212;
  }
  .ns-offer-card__pct {
    display: inline-block;
    margin-top: 6px;
    color: var(--ns-accent, #6d388b);
    font-size: 1.05rem;
    font-weight: 800;
  }
  .ns-offer-card__actions {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ns-offer-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px 18px;
    border-radius: 999px;
    background: var(--ns-accent, #6d388b);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 2px solid var(--ns-accent, #6d388b);
    transition: filter 0.2s ease, transform 0.2s ease;
  }
  .ns-offer-card__cta:hover {
    filter: brightness(1.06);
    transform: translateY(-1px);
  }
  .ns-offer-card__guarantee {
    margin: 0;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ns-accent, #6d388b);
    letter-spacing: 0.04em;
  }
  @media (max-width: 760px) {
    .ns-offers { padding: 32px 12px 48px; }
    .ns-offer-card {
      grid-template-columns: 1fr;
      padding: 14px;
      gap: 14px;
    }
    .ns-offer-card__media { min-height: 200px; }
    .ns-offer-card__copy { padding: 4px; }
  }
</style>

{% schema %}
{
  "name": "Catalogo de ofertas",
  "tag": "section",
  "class": "section-ns-offers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Ofertas especiales"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtitulo",
      "default": "Elige tu producto y continua al detalle."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleccion"
    },
    {
      "type": "checkbox",
      "id": "show_collection_title",
      "label": "Mostrar titulo de coleccion",
      "default": false
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 1,
      "max": 50,
      "step": 1,
      "label": "Cantidad de productos",
      "default": 12
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del boton",
      "default": "ORDER NOW"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Texto de garantia",
      "default": "Garantia NOVASHOP – 30 Dias"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color acento",
      "default": "#6d388b"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo seccion",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Fondo card",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Redondeo cards",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Catalogo de ofertas"
    }
  ]
}
{% endschema %}
