<style>
  /* Sizing adjustments for the flip clock boxes */
  @media (min-width: 901px) {
    {% if section.settings.counter_size == 'sml' %}
      .banner_special ul.flip {
        width: 75px !important;
        height: 56px !important;
        font-size: 1.4rem !important;
        line-height: 1.95em !important;
      }
      .banner_special .clock {
        padding: 0.5em 0.35em !important;
      }
    {% elsif section.settings.counter_size == 'lrg' %}
      .banner_special ul.flip {
        width: 110px !important;
        height: 82px !important;
        font-size: 2.3rem !important;
        line-height: 1.83em !important;
      }
      .banner_special .clock {
        padding: 1em 0.75em !important;
      }
    {% else %}
      /* Medium (med) */
      .banner_special ul.flip {
        width: 90px !important;
        height: 68px !important;
        font-size: 1.8rem !important;
        line-height: 1.83em !important;
      }
      .banner_special .clock {
        padding: 0.75em 0.5em !important;
      }
    {% endif %}
  }

  /* Prevent flip clock boxes from wrapping on desktop */
  .clock #ticker {
    display: flex !important;
    flex-wrap: nowrap !important;
    align-items: center;
    justify-content: center;
    gap: 0.15em;
    width: 100%;
  }

  /* Ensure labels align perfectly with the boxes by shrinking container to fit */
  .banner_special .clock {
    width: fit-content !important;
    max-width: 100%;
  }

  /* Position adjustments based on theme settings */
  @media (min-width: 1201px) {
    {% if section.settings.counter_position == 'center' %}
      .banner_special .bottom {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        text-align: center !important;
      }
      .banner_special .bottom .counter {
        width: 100% !important;
        max-width: 500px !important;
        margin: 0 auto 20px !important;
      }
      .banner_special .clock {
        margin: 0 auto !important;
      }
      .banner_special .bottom .copy {
        width: 100% !important;
        margin-left: 0 !important;
      }
    {% elsif section.settings.counter_position == 'right' %}
      .banner_special .bottom {
        display: flex !important;
        flex-direction: row-reverse !important;
        align-items: center !important;
      }
      .banner_special .bottom .counter {
        width: 40% !important;
        margin-left: 3% !important;
      }
      .banner_special .clock {
        margin-left: auto !important;
        margin-right: 0 !important;
      }
      .banner_special .bottom .copy {
        width: 55% !important;
        margin-left: 0 !important;
        text-align: left !important;
      }
    {% else %}
      /* Left / default */
      .banner_special .bottom {
        display: flex !important;
        align-items: center !important;
      }
      .banner_special .bottom .counter {
        width: 40% !important;
      }
      .banner_special .clock {
        margin-left: 0 !important;
        margin-right: auto !important;
      }
      .banner_special .bottom .copy {
        width: 55% !important;
        margin-left: 3% !important;
      }
    {% endif %}
  }
</style>

