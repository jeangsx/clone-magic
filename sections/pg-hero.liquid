{% comment %} Estilos editables (toda la seccion) {% endcomment %}
<div
  class="pg-sec-style pg-sec-align-{{ section.settings.style_align }}{% if section.settings.style_hide_mobile %} pg-sec-hide-mobile{% endif %}{% if section.settings.style_hide_desktop %} pg-sec-hide-desktop{% endif %}"
  style="
    --pg-sec-pad-y: {{ section.settings.style_pad_y }}px;
    --pg-sec-pad-x: {{ section.settings.style_pad_x }}px;
    --pg-sec-max: {% if section.settings.style_max_width > 0 %}{{ section.settings.style_max_width }}px{% else %}none{% endif %};
    --pg-sec-h-size: {{ section.settings.style_heading_size }}px;
    --pg-sec-t-size: {{ section.settings.style_text_size }}px;
    --pg-sec-bg: {{ section.settings.style_bg | default: 'transparent' }};
    --pg-sec-h-color: {{ section.settings.style_heading_color }};
    --pg-sec-t-color: {{ section.settings.style_text_color }};
    --pg-sec-btn-fs: {{ section.settings.style_btn_font }}px;
    --pg-sec-btn-py: {{ section.settings.style_btn_pad_y }}px;
    --pg-sec-btn-px: {{ section.settings.style_btn_pad_x }}px;
    --pg-sec-btn-radius: {{ section.settings.style_btn_radius }}px;
    --pg-sec-btn-bg: {{ section.settings.style_btn_bg }};
    --pg-sec-btn-color: {{ section.settings.style_btn_text }};
    --pg-sec-min-h: {{ section.settings.style_min_height }}px;
    --pg-sec-img-w: {{ section.settings.style_image_width }}%;
    --pg-sec-img-h: {% if section.settings.style_image_max_height > 0 %}{{ section.settings.style_image_max_height }}px{% else %}none{% endif %};
    --pg-sec-img-radius: {{ section.settings.style_image_radius }}px;
  "
>
<div class="banner_special body_full_nomar">
  <div class="body_full" style="max-width:{{ section.settings.hero_content_max_width }}px;">
    <div class="headings">
      {% if section.settings.hero_subtitle != blank %}
        <span class="heading">{{ section.settings.hero_subtitle }}</span>
      {% endif %}
      {% if section.settings.hero_title != blank %}
        <div class="pg-hero-title">{{ section.settings.hero_title }}</div>
      {% endif %}
      {% if section.settings.banner_image != blank %}
        <img
          src="{{ section.settings.banner_image | image_url: width: 640 }}"
          alt="{{ section.settings.banner_image.alt | escape }}"
          width="{{ section.settings.banner_image.width }}"
          height="{{ section.settings.banner_image.height }}"
          style="width:{{ section.settings.banner_width }}px;max-width:100%;margin:12px auto 0;border-radius:{{ section.settings.banner_radius }}px;height:auto;display:block;"
          loading="lazy"
        >
      {% endif %}
    </div>

    {% if section.settings.show_bottles %}
      <div class="bottles">
        {% assign bottle = section.settings.bottle_image %}
        {% for i in (1..3) %}
          {% if bottle != blank %}
            <img src="{{ bottle | image_url: width: 400 }}" alt="ProstaGenix" width="400" height="400" loading="lazy" style="width:{{ section.settings.bottle_width }}px;max-width:100%;height:auto;">
          {% else %}
            <img src="https://www.prostagenix.com/images/product/bottle.png" alt="ProstaGenix - bottle" width="400" height="400" loading="lazy" style="width:{{ section.settings.bottle_width }}px;max-width:100%;height:auto;">
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="bottom">
      {% if section.settings.show_countdown %}
        <div class="counter">
          <div class="clock">
            <div id="ticker"></div>
            <ul class="labels">
              <li>Días</li>
              <li>Horas</li>
              <li>Min</li>
              <li>Seg</li>
            </ul>
          </div>
        </div>
      {% endif %}
      <div class="copy">
        {% if section.settings.countdown_label != blank %}
          <span class="heading">{{ section.settings.countdown_label }}</span>
        {% endif %}
        {% if section.settings.hero_urgency != blank %}
          <span class="heading">{{ section.settings.hero_urgency }}</span>
        {% endif %}
      </div>
    </div>
  </div>
</div>
</div>

{% schema %}
{
  "name": "PG Hero / Sale",
  "tag": "section",
  "class": "pg-section-hero",
  "settings": [
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtítulo",
      "default": "GREAT DEAL - Order Now!"
    },
    {
      "type": "richtext",
      "id": "hero_title",
      "label": "Título",
      "default": "<p>One Day <strong>Super Sale</strong> <span>Stock Up Now!</span></p>"
    },
    {
      "type": "text",
      "id": "hero_urgency",
      "label": "Urgencia",
      "default": "HUGE SAVINGS - 70% OFF NOW!"
    },
    {
      "type": "text",
      "id": "countdown_label",
      "label": "Texto del contador",
      "default": "Hurry Up! Time is Ticking..."
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Mostrar contador",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bottles",
      "label": "Mostrar botellas",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "bottle_image",
      "label": "Imagen botella (opcional)"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner editable (opcional)"
    },
    {
      "type": "header",
      "content": "Tamanos del banner"
    },
    {
      "type": "range",
      "id": "hero_content_max_width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Ancho del contenido Hero",
      "default": 1200
    },
    {
      "type": "range",
      "id": "banner_width",
      "min": 100,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Ancho de imagen banner",
      "default": 320
    },
    {
      "type": "range",
      "id": "banner_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio de imagen banner",
      "default": 12
    },
    {
      "type": "range",
      "id": "bottle_width",
      "min": 80,
      "max": 500,
      "step": 20,
      "unit": "px",
      "label": "Ancho de cada botella",
      "default": 400
    },
    {
      "type": "header",
      "content": "Estilos de seccion"
    },
    {
      "type": "range",
      "id": "style_pad_y",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_pad_x",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_max_width",
      "min": 0,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Ancho maximo (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_heading_size",
      "min": 14,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Tamano titulos",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano texto",
      "default": 16
    },
    {
      "type": "color",
      "id": "style_bg",
      "label": "Fondo seccion"
    },
    {
      "type": "color",
      "id": "style_heading_color",
      "label": "Color titulos",
      "default": "#0b1a3a"
    },
    {
      "type": "color",
      "id": "style_text_color",
      "label": "Color texto",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "style_btn_font",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamano botones",
      "default": 15
    },
    {
      "type": "range",
      "id": "style_btn_pad_y",
      "min": 6,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Padding vertical boton",
      "default": 14
    },
    {
      "type": "range",
      "id": "style_btn_pad_x",
      "min": 10,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal boton",
      "default": 28
    },
    {
      "type": "range",
      "id": "style_btn_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio botones",
      "default": 24
    },
    {
      "type": "color",
      "id": "style_btn_bg",
      "label": "Boton fondo",
      "default": "#e65600"
    },
    {
      "type": "color",
      "id": "style_btn_text",
      "label": "Boton texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "style_min_height",
      "min": 0,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Altura minima (0 = auto)",
      "default": 0
    },
    {
      "type": "select",
      "id": "style_align",
      "label": "Alineacion del contenido",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "style_image_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Ancho maximo de imagenes",
      "default": 100
    },
    {
      "type": "range",
      "id": "style_image_max_height",
      "min": 0,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Alto maximo imagenes (0 = auto)",
      "default": 0
    },
    {
      "type": "range",
      "id": "style_image_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio de imagenes",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "style_hide_mobile",
      "label": "Ocultar en celular",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "style_hide_desktop",
      "label": "Ocultar en desktop",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "PG Hero / Sale"
    }
  ]
}
{% endschema %}
