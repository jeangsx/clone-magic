<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'pg-theme.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --pg-blue: {{ settings.color_blue }};
        --pg-orange: {{ settings.color_orange }};
        --pg-red: {{ settings.color_red }};
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: Montserrat, system-ui, sans-serif;
        background: linear-gradient(180deg, #eef3fb, #fff);
      }
    </style>
  </head>
  <body class="pg-body">
    {{ content_for_layout }}
  </body>
</html>
