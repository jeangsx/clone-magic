{% comment %}
  Shared style + text settings for product buybox sections.
  Include via: {% render 'pg-buybox-from-section', product: product, defaults: 'pdp' %}
{% endcomment %}

{% liquid
  if defaults == 'preview'
    assign _show_bar = section.settings.show_bar
    assign _show_back = section.settings.show_back
  else
    assign _show_bar = section.settings.show_bar
    assign _show_back = section.settings.show_back
  endif
%}

{% render 'pg-product-buybox',
  product: product,
  show_bar: section.settings.show_bar,
  show_back: section.settings.show_back,
  show_description: section.settings.show_description,
  show_rating: section.settings.show_rating,
  show_benefits: section.settings.show_benefits,
  show_hot_sale: section.settings.show_hot_sale,
  bar_text: section.settings.bar_text,
  rating_text: section.settings.rating_text,
  doctor_badge: section.settings.doctor_badge,
  benefit_1: section.settings.benefit_1,
  benefit_2: section.settings.benefit_2,
  benefit_3: section.settings.benefit_3,
  hot_sale_label: section.settings.hot_sale_label,
  hot_sale_text: section.settings.hot_sale_text,
  offer_badge: section.settings.offer_badge,
  in_stock_label: section.settings.in_stock_label,
  sold_out_label: section.settings.sold_out_label,
  total_label: section.settings.total_label,
  save_label: section.settings.save_label,
  cta_label: section.settings.cta_label,
  back_label: section.settings.back_label,
  description_title: section.settings.description_title,
  off_prefix: section.settings.off_prefix,
  off_suffix: section.settings.off_suffix,
  description_placement: section.settings.description_placement,
  gallery_position: section.settings.gallery_position,
  title_size: section.settings.title_size,
  cta_font_size: section.settings.cta_font_size,
  cta_pad_y: section.settings.cta_pad_y,
  cta_pad_x: section.settings.cta_pad_x,
  cta_radius: section.settings.cta_radius,
  desc_font_size: section.settings.desc_font_size,
  desc_max_width: section.settings.desc_max_width,
  desc_pad: section.settings.desc_pad,
  desc_radius: section.settings.desc_radius,
  desc_margin_top: section.settings.desc_margin_top,
  section_max_width: section.settings.section_max_width,
  section_pad_y: section.settings.section_pad_y,
  section_pad_x: section.settings.section_pad_x,
  gallery_min_height: section.settings.gallery_min_height,
  color_bar: section.settings.color_bar,
  color_cta_bg: section.settings.color_cta_bg,
  color_cta_text: section.settings.color_cta_text,
  color_cta_border: section.settings.color_cta_border,
  color_desc_bg: section.settings.color_desc_bg,
  color_desc_title: section.settings.color_desc_title,
  color_title: section.settings.color_title,
  color_badge: section.settings.color_badge,
  color_off: section.settings.color_off
%}
