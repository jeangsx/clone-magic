{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Gift Card — {{ shop.name }}</title>
    {{ content_for_header }}
    <script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>
    <style>
      body {
        margin: 0;
        font-family: Montserrat, system-ui, sans-serif;
        background: #f7f8fb;
        color: #0b1a3a;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .pg-gc {
        background: #fff;
        border: 1px solid #e3e6ee;
        border-radius: 16px;
        padding: 32px;
        max-width: 420px;
        width: 100%;
        text-align: center;
      }
      .pg-gc h1 { color: #054497; font-weight: 900; margin: 0 0 8px; }
      .pg-gc .code {
        font-size: 22px;
        font-weight: 900;
        letter-spacing: 2px;
        margin: 20px 0;
        padding: 12px;
        background: #eef3fb;
        border-radius: 10px;
      }
      .pg-gc .balance { font-size: 28px; font-weight: 900; color: #f39200; }
    </style>
  </head>
  <body>
    <div class="pg-gc">
      <img
        src="https://www.prostagenix.com/190109/img/logo.png"
        alt="{{ shop.name }}"
        width="160"
        height="48"
        style="max-width:160px;height:auto;margin-bottom:16px;"
      >
      <h1>Gift Card</h1>
      {% unless gift_card.enabled %}
        <p>Esta gift card está deshabilitada.</p>
      {% endunless %}
      {% if gift_card.expired %}
        <p>Esta gift card ha expirado.</p>
      {% endif %}
      <div class="balance">{{ gift_card.balance | money_with_currency }}</div>
      <p style="color:#666;font-size:13px;">de {{ gift_card.initial_value | money_with_currency }}</p>
      <div class="code">{{ gift_card.code | format_code }}</div>
      <div id="qr-code" style="display:flex;justify-content:center;margin:16px 0;"></div>
      {% if gift_card.pass_url %}
        <p><a href="{{ gift_card.pass_url }}">Add to Apple Wallet</a></p>
      {% endif %}
      <p><a href="{{ shop.url }}" style="color:#054497;font-weight:700;">{{ shop.name }}</a></p>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        if (typeof QRCode === 'undefined') return;
        new QRCode(document.getElementById('qr-code'), {
          text: {{ gift_card.qr_identifier | json }},
          width: 120,
          height: 120
        });
      });
    </script>
  </body>
</html>
